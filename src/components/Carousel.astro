---
interface Props {
  slides: ImageMetadata[];
  autoplay?: boolean;
  interval?: number;
  showIndicators?: boolean;
  initialSlide?: number;
}

const {
  slides,
  autoplay = false,
  interval = 5000,
  showIndicators = true,
  initialSlide = 0,
} = Astro.props;
---

<astro-carousel
  class="carousel-container block"
  data-autoplay={String(autoplay)}
  data-interval={interval}
  data-initial-slide={initialSlide}
>
  <div class="carousel-skeleton" aria-hidden="true">
    <div class="skeleton-image shimmer"></div>
    {
      showIndicators && (
        <div class="skeleton-indicators">
          {slides.map((_, index) => (
            <div
              class={`skeleton-dot shimmer ${index === initialSlide ? "skeleton-dot--active" : ""}`}
            />
          ))}
        </div>
      )
    }
  </div>

  <div class="carousel-content" style="display: none;">
    <button
      data-carousel-btn="prev"
      aria-label="previous"
      class="top-0 left-0 absolute z-10 h-full w-1/5 opacity-0 hover:opacity-50 hover:bg-gray-700 transition-opacity"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        class="size-20 fill-white mx-auto"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m18.75 4.5-7.5 7.5 7.5 7.5m-6-15L5.25 12l7.5 7.5"></path>
      </svg>
    </button>
    <button
      data-carousel-btn="next"
      aria-label="next"
      class="top-0 right-0 absolute z-10 h-full w-1/5 opacity-0 hover:opacity-50 hover:bg-gray-700 transition-opacity"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        class="size-20 fill-white mx-auto"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m5.25 4.5 7.5 7.5-7.5 7.5m6-15 7.5 7.5-7.5 7.5"></path>
      </svg>
    </button>

    <div class="carousel rounded-3xl">
      {
        slides.map((slide, index) => (
          /* Using data attributes instead of IDs to preserve styling rules while maintaining instance scoping */
          <div data-slide-index={index} class="carousel-item">
            <img
              src={slide.src}
              alt={`Slide ${index + 1}`}
              class="display-image"
            />
          </div>
        ))
      }
    </div>

    {
      showIndicators && (
        <div class="flex justify-center w-full py-2 gap-2 carousel-indicators">
          {slides.map((_, index) => (
            <button
              class={`btn btn-xs btn-circle ${index === initialSlide ? "btn-primary" : "btn-ghost"}`}
              data-indicator-index={index}
              aria-label={`Go to slide ${index + 1}`}
            />
          ))}
        </div>
      )
    }
  </div>
</astro-carousel>

<script>
  class AstroCarousel extends HTMLElement {
    private currentSlide = 0;
    private totalSlides = 0;
    private autoplayInterval: ReturnType<typeof setInterval> | null = null;

    private skeleton!: HTMLElement | null;
    private content!: HTMLElement | null;
    private indicators!: NodeListOf<HTMLButtonElement>;
    private prevBtn!: HTMLButtonElement | null;
    private nextBtn!: HTMLButtonElement | null;

    connectedCallback() {
      this.skeleton = this.querySelector(".carousel-skeleton");
      this.content = this.querySelector(".carousel-content");
      // Select items safely scoped *inside* this specific custom element instance
      const items = this.querySelectorAll("[data-slide-index]");
      this.indicators = this.querySelectorAll("[data-indicator-index]");
      this.prevBtn = this.querySelector('[data-carousel-btn="prev"]');
      this.nextBtn = this.querySelector('[data-carousel-btn="next"]');

      this.totalSlides = items.length;

      const images = this.querySelectorAll(
        ".display-image",
      ) as NodeListOf<HTMLImageElement>;
      this.initImageLoader(images);
      this.initControls();
    }

    disconnectedCallback() {
      this.stopAutoplay();
    }

    private initImageLoader(images: NodeListOf<HTMLImageElement>) {
      if (images.length === 0) {
        this.revealCarousel();
        return;
      }

      let loadedCount = 0;
      const checkReveal = () => {
        loadedCount++;
        if (loadedCount === images.length) this.revealCarousel();
      };

      images.forEach((img) => {
        if (img.complete && img.naturalWidth > 0) {
          checkReveal();
        } else {
          img.addEventListener("load", checkReveal);
          img.addEventListener("error", checkReveal);
        }
      });
    }

    private revealCarousel() {
      if (this.skeleton) this.skeleton.style.display = "none";
      if (this.content) this.content.style.display = "";

      const initialSlideAttr = this.getAttribute("data-initial-slide");
      this.goToSlide(initialSlideAttr ? parseInt(initialSlideAttr, 10) : 0);
      this.initAutoplay();
    }

    private initControls() {
      this.prevBtn?.addEventListener("click", () =>
        this.goToSlide(this.currentSlide - 1),
      );
      this.nextBtn?.addEventListener("click", () =>
        this.goToSlide(this.currentSlide + 1),
      );

      this.indicators.forEach((indicator) => {
        indicator.addEventListener("click", () => {
          const index = parseInt(
            indicator.getAttribute("data-indicator-index") || "0",
            10,
          );
          this.goToSlide(index);
        });
      });
    }

    private goToSlide(index: number) {
      if (this.totalSlides === 0) return;

      this.currentSlide = (index + this.totalSlides) % this.totalSlides;

      // Find the specific slide scoped within this container using data attributes
      const activeSlide = this.querySelector(
        `[data-slide-index="${this.currentSlide}"]`,
      );
      if (activeSlide) {
        activeSlide.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "start",
        });
      }

      this.indicators.forEach((indicator, i) => {
        indicator.classList.toggle("btn-ghost", i !== this.currentSlide);
        indicator.classList.toggle("btn-primary", i === this.currentSlide);
      });
    }

    private initAutoplay() {
      const isAutoplay = this.getAttribute("data-autoplay") === "true";
      if (!isAutoplay) return;

      const interval = parseInt(
        this.getAttribute("data-interval") || "5000",
        10,
      );

      const start = () => {
        this.autoplayInterval = setInterval(
          () => this.goToSlide(this.currentSlide + 1),
          interval,
        );
      };

      start();
      this.addEventListener("mouseenter", () => this.stopAutoplay());
      this.addEventListener("mouseleave", start);
    }

    private stopAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }
  }

  if (!customElements.get("astro-carousel")) {
    customElements.define("astro-carousel", AstroCarousel);
  }
</script>

<style>
  /* Retained your original styling layout styles completely untouched */
  .carousel-container {
    position: relative;
    overflow: hidden;
  }

  /* ── Skeleton ── */
  .carousel-skeleton {
    width: 100%;
    border-radius: 1.5rem;
    overflow: hidden;
  }

  .skeleton-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 1.5rem;
  }

  .skeleton-indicators {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 0 0.75rem;
  }

  .skeleton-dot {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background-color: oklch(var(--b3, 0.9 0 0));
  }

  .skeleton-dot--active {
    background-color: oklch(var(--p, 0.6 0.2 250));
    opacity: 0.4;
  }

  /* Shimmer animation */
  @keyframes skeleton-shimmer {
    0% {
      background-position: 200% center;
    }
    100% {
      background-position: -200% center;
    }
  }

  .shimmer {
    background: linear-gradient(
      90deg,
      oklch(var(--b2, 0.85 0 0)) 25%,
      oklch(var(--b3, 0.9 0 0)) 50%,
      oklch(var(--b2, 0.85 0 0)) 75%
    );
    background-size: 200% 100%;
    animation: skeleton-shimmer 1.6s ease-in-out infinite;
  }

  /* ── Carousel content ── */
  .carousel-content {
    position: relative;
  }

  .display-image {
    max-width: 100%;
    max-height: calc(100vh - 125px);
    aspect-ratio: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }
</style>
